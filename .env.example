# --- Database ---
DB_USER=user
DB_PASSWORD=password
DB_NAME=interview_db

# --- Security ---
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-prod

# --- AI APIs ---
GOOGLE_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Backend ---
# If running with Docker, use 'db' as hostname: postgresql://user:password@db:5432/interview_db
DATABASE_URL=postgresql://user:password@localhost:5432/interview_db
REDIS_URL=redis://localhost:6379/0

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# --- Production Notes ---
# 1. Ensure JWT_SECRET_KEY is at least 32 characters long.
# 2. In production, change GOOGLE_API_KEY and OPENAI_API_KEY to restricted production keys.
# 3. Use 'db' and 'redis' hostnames in DATABASE_URL/REDIS_URL when deploying via Docker Compose.
# 4. Vapi uses NEXT_PUBLIC_* browser keys only. Never put a Vapi private key in the frontend.
